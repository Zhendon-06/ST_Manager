<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/wechat_background"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="22dp"
            android:paddingEnd="22dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="学生教师信息管理系统"
                android:textColor="@color/white"
                android:textSize="23sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textStudentCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="学生记录"
                        android:textColor="#E9FFF3"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textTeacherCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="教师记录"
                        android:textColor="#E9FFF3"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/segmentGroup"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                app:checkedButton="@id/buttonStudents"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonStudents"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:text="学生管理"
                    android:textColor="@color/wechat_toggle_text"
                    app:backgroundTint="@color/wechat_toggle_bg"
                    app:icon="@drawable/ic_person"
                    app:iconGravity="textStart"
                    app:iconTint="@color/wechat_toggle_text"
                    app:rippleColor="@color/wechat_ripple"
                    app:strokeColor="@color/wechat_toggle_stroke" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonTeachers"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:text="教师管理"
                    android:textColor="@color/wechat_toggle_text"
                    app:backgroundTint="@color/wechat_toggle_bg"
                    app:icon="@drawable/ic_teacher"
                    app:iconGravity="textStart"
                    app:iconTint="@color/wechat_toggle_text"
                    app:rippleColor="@color/wechat_ripple"
                    app:strokeColor="@color/wechat_toggle_stroke" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/searchLayout"
                style="@style/Widget.STManager.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="按姓名、学号、学院、班级或电话查询"
                app:endIconMode="clear_text"
                app:startIconDrawable="@drawable/ic_search">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textColor="@color/wechat_text_primary"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_surface_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textModuleTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="学生管理"
                            android:textColor="@color/wechat_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textModuleSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="添加、查看、修改、删除和条件查询学生资料"
                            android:textColor="@color/wechat_text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/textCurrentCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_selected"
                        android:paddingStart="12dp"
                        android:paddingTop="7dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="7dp"
                        android:text="0 条"
                        android:textColor="@color/wechat_green"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="14dp"
                    android:layout_weight="1"
                    android:minHeight="260dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerStudents"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:paddingBottom="80dp"
                        tools:itemCount="3"
                        tools:listitem="@layout/item_student" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerTeachers"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:paddingBottom="80dp"
                        android:visibility="gone"
                        tools:itemCount="3"
                        tools:listitem="@layout/item_teacher" />

                    <LinearLayout
                        android:id="@+id/emptyState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_empty_state"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="26dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_empty" />

                        <TextView
                            android:id="@+id/textEmptyTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="暂无学生资料"
                            android:textColor="@color/wechat_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textEmptyBody"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center"
                            android:text="点击右下角添加第一条记录"
                            android:textColor="@color/wechat_text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="22dp"
        android:text="添加学生"
        android:textColor="@color/wechat_button_text"
        app:backgroundTint="@color/wechat_button_bg"
        app:icon="@drawable/ic_add"
        app:iconTint="@color/wechat_button_text"
        app:rippleColor="@color/wechat_ripple" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
